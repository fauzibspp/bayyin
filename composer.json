{
  "name": "fauzibspp/bayyin",
  "description": "Bayyin is a lightweight PHP native MVC framework with CLI scaffolding, migrations, seeders, AJAX CRUD, and API module generation.",
  "type": "project",
  "license": "MIT",
  "keywords": [
    "bayyin",
    "php",
    "mvc",
    "framework",
    "crud",
    "scaffolding",
    "adminlte",
    "api"
  ],
  "homepage": "https://github.com/fauzibspp/bayyin",
  "support": {
    "source": "https://github.com/fauzibspp/bayyin"
  },
  "require": {
    "php": ">=8.1",
    "firebase/php-jwt": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
