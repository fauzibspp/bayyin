{
  "name": "bayyin/framework",
  "description": "Bayyin is a lightweight PHP native MVC framework with CLI scaffolding, migrations, seeders, AJAX CRUD, and API module generation.",
  "type": "project",
  "license": "proprietary",
  "keywords": [
    "bayyin",
    "php",
    "mvc",
    "framework",
    "crud",
    "scaffolding",
    "adminlte",
    "api"
  ],
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}